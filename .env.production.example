APP_NAME=Beconnect
APP_ENV=production
APP_KEY=   # será gerado pelo artisan key:generate
APP_DEBUG=false
APP_URL=https://beconnected.escaleno.co.mz
ASSET_URL=https://beconnected.escaleno.co.mz

APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt

# Base de dados MySQL (cPanel)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpanel_beconnect
DB_USERNAME=cpanel_beconnect_user
DB_PASSWORD=SENHA_FORTE_AQUI

# Redis (servidor local)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# Sessions via Redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_CONNECTION=default

# Cache via Redis
CACHE_STORE=redis

# Queue — database como fallback se Redis indisponível
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mail.escaleno.co.mz
MAIL_PORT=587
MAIL_USERNAME=noreply@beconnected.escaleno.co.mz
MAIL_PASSWORD=SENHA_MAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@beconnected.escaleno.co.mz
MAIL_FROM_NAME=Beconnect

# Octane — desactivado em cPanel (usar PHP-FPM nativo)
OCTANE_SERVER=

# Logs
LOG_CHANNEL=daily
LOG_LEVEL=error
